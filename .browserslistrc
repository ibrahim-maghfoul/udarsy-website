# Target modern browsers that natively ship Baseline 2022 features.
# Eliminates ~14 KB of polyfills for: Array.at, flat, flatMap,
# Object.fromEntries, Object.hasOwn, String.trimStart/trimEnd.
# Binding constraints: Array.at (Chrome 92, Safari 15.4) and
# Object.hasOwn (Chrome 93, Firefox 92, Safari 15.4, Edge 93).

[production]
chrome >= 93
chromium >= 93
edge >= 93
firefox >= 92
safari >= 15.4
opera >= 79
samsung >= 17
not dead
not op_mini all

[development]
last 1 chrome version
last 1 firefox version
last 1 safari version